setwd("C:/Users/Manal/OneDrive/Bureau/RagFrame")
library(ScottKnottESD)
wide <- read.csv("evaluation/outputs/scott_knott_F1_All_wide.csv", check.names = FALSE)
rownames(wide) <- wide$UseCase
wide$UseCase <- NULL
wide <- data.frame(lapply(wide, as.numeric), check.names = FALSE)
sk <- sk_esd(wide, version = "p", alpha = 0.05)
print(sk)
groups <- data.frame(
  Model = names(sk$groups),
  SK_Group = as.integer(sk$groups),
  row.names = NULL
)
print(groups)
write.csv(
  groups,
  "evaluation/outputs/scott_knott_F1_All_groups.csv",
  row.names = FALSE
)
